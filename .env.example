# =================================
# Arena360 Environment Variables
# =================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/arena360?appName=Cluster0

# JWT secret — must be a strong random string (64+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Stripe (payment gateway — configure when ready)
STRIPE_SECRET_KEY=

# App base URL (update per environment)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_COUNTRY_CODE=92

# Google Gemini API key (for AI chatbot)
GEMINI_API_KEY=
